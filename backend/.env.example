# ── Veritabanı ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://fw_user:fw_password@localhost:5432/financial_wisdom

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT — SECRET_KEY'i mutlaka değiştir! ─────────────────────────────────────
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_supersecretkey
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Uygulama ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173

# ── E-posta Doğrulama (SMTP) ─────────────────────────────────────────────────
# Gmail için: Google Hesabı → Güvenlik → 2FA etkinleştir → Uygulama Şifreleri
# EMAILS_ENABLED=false → mail göndermez, token terminal loguna yazılır (geliştirme)
# EMAILS_ENABLED=true  → gerçek mail gönderir

EMAILS_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=senin@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
